{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/envGroupMeta",
  "title": "envGroupMeta",
  "type": "object",
  "required": [
    "id",
    "name",
    "ownerId",
    "createdAt",
    "updatedAt",
    "serviceLinks"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "ownerId": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "serviceLinks": {
      "description": "List of serviceIds linked to the envGroup",
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/envGroupLink"
      }
    },
    "environmentId": {
      "type": "string"
    }
  }
}