{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/routePut",
  "title": "routePut",
  "type": "object",
  "required": [
    "type",
    "source",
    "destination"
  ],
  "properties": {
    "type": {
      "$ref": "#/components/schemas/routeType"
    },
    "source": {
      "type": "string",
      "example": "/:bar/foo"
    },
    "destination": {
      "type": "string",
      "example": "/foo/:bar"
    }
  }
}